{
  "description": "Blocks grep/rg and find in Bash commands, enforcing ast-grep and the Glob tool instead",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-bash-tools.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
